# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Server
PORT=3001
NODE_ENV=development

# Rails Backend
RAILS_BACKEND_URL=http://localhost:3000
RAILS_AUTH_TOKEN=your_rails_jwt_token_here

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
